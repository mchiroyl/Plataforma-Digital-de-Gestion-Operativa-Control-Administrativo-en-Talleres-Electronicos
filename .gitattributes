# Normalizar saltos de linea: checkout en estilo del OS, almacenar en LF
* text=auto

# Forzar LF en archivos de código fuente
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.env.example text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.prettierrc text eol=lf

# Binarios — sin conversión
*.png binary
*.jpg binary
*.svg binary
*.ico binary
*.xlsx binary
*.webp binary
