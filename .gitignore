# =============================================================================
# .gitignore — Plataforma Digital de Gestión Operativa para Talleres Electrónicos
# =============================================================================
#
# PRINCIPIO DE SEGURIDAD (OWASP / GitHub Security Best Practices):
#   "Una vez que un secreto toca el historial de git, se considera comprometido,
#    incluso si se elimina en un commit posterior."
#
# Todo archivo sensible debe ignorarse ANTES de existir en el repositorio.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 1 — SECRETOS Y VARIABLES DE ENTORNO
# Riesgo: exposición de credenciales de base de datos, JWT_SECRET, API keys.
# Impacto: acceso no autorizado al sistema completo.
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
backend/.env
frontend/.env
# Mantener plantillas de referencia (sin valores reales)
!.env.example
!**/.env.example


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 2 — CLAVES CRIPTOGRÁFICAS Y CERTIFICADOS
# Riesgo: filtración de claves privadas SSL/TLS, SSH o de firma de tokens.
# Impacto: suplantación de identidad, man-in-the-middle, acceso remoto.
# ─────────────────────────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.cer
*.der
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
*.pub
*.ppk
ssl/
certs/
certificates/


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 3 — SESIÓN DE WHATSAPP (tokens de autenticación reales)
# Riesgo: los archivos .wwebjs_auth contienen cookies de sesión activas.
# Impacto: acceso total a la cuenta de WhatsApp vinculada al sistema.
# ─────────────────────────────────────────────────────────────────────────────
.wwebjs_auth/
.wwebjs_cache/
backend/.wwebjs_auth/
backend/.wwebjs_cache/


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 4 — ARCHIVOS DE SEGURIDAD CON CREDENCIALES EN TEXTO PLANO
# rls_ready.sql se genera localmente sustituyendo placeholders con contraseñas
# reales del .env. Nunca debe existir en el repositorio.
# ─────────────────────────────────────────────────────────────────────────────
backend/prisma/security/rls_ready.sql


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 5 — VOLCADOS Y BACKUPS DE BASE DE DATOS
# Riesgo: contienen datos personales de clientes (DPI, teléfonos, órdenes).
# Impacto: violación de privacidad, incumplimiento normativo (GDPR / Ley local).
# ─────────────────────────────────────────────────────────────────────────────
*.sql.gz
*.dump
*.bak
*.backup
db-dump/
backups/
exports/


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 6 — PREVENCIÓN POR NOMBRE (archivos con apariencia de secreto)
# Bloquea cualquier archivo cuyo nombre sugiera que contiene credenciales.
# Las excepciones protegen el código fuente legítimo que menciona estos términos.
# ─────────────────────────────────────────────────────────────────────────────
*secret*
*password*
*passwd*
*credential*
*apikey*
*api_key*
*private_key*
# Excepciones: código fuente que referencia estos conceptos (interfaces, DTOs)
!**/src/**/*secret*
!**/src/**/*token*
!**/src/**/*credential*
!**/src/**/*password*


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 7 — DOCUMENTACIÓN INTERNA (no pública)
# Contiene información operativa, propuestas y bitácoras del proyecto.
# ─────────────────────────────────────────────────────────────────────────────
docs/


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 8 — DEPENDENCIAS (nunca se versionan)
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 9 — COMPILADOS Y ARTEFACTOS DE BUILD
# ─────────────────────────────────────────────────────────────────────────────
dist/
**/dist/
build/
*.tsbuildinfo
backend/node_modules/.prisma/


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 10 — LOGS (pueden contener trazas con datos personales o rutas internas)
# Riesgo: los logs pueden revelar stack traces, IPs, usuarios o estructura interna.
# ─────────────────────────────────────────────────────────────────────────────
*.log
*.err.log
*.out.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 11 — CACHÉ Y ARCHIVOS TEMPORALES
# ─────────────────────────────────────────────────────────────────────────────
.npm
.eslintcache
.cache/
.parcel-cache/
.turbo/
*.tmp
*.temp


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 12 — SISTEMA OPERATIVO
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 13 — EDITORES E IDEs (configuraciones locales del desarrollador)
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 14 — COBERTURA Y REPORTES DE PRUEBAS
# ─────────────────────────────────────────────────────────────────────────────
coverage/
**/coverage/
.nyc_output/


# ─────────────────────────────────────────────────────────────────────────────
# BLOQUE 15 — DOCUMENTOS ACADÉMICOS Y RENDERS DE TESIS
# Evita la indexación pública de borradores de tesis, marcos teóricos o matrices.
# ─────────────────────────────────────────────────────────────────────────────
*.docx
docx_render_marco/
docx_render_marco_v1/
scripts/generar_marco_teorico_docx.py
